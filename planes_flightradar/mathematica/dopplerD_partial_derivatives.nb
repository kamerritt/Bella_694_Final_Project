Cell[BoxData[
 RowBox[{
  RowBox[{"partialt0X", "[", 
   RowBox[{"v_", ",", "t0_", ",", "d0_", ",", "fs_", ",", "c_", ",", "tp_"}], 
   "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"d0", " ", "fs", " ", 
