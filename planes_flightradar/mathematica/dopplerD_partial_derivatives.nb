Cell[CellGroupData[{

Cell["This factor will help shorten the explicit expressions", "Subsection",
 CellChangeTimes->{{3.960055700726102*^9, 3.9600557471588783`*^9}, {
   3.960748641201867*^9, 3.9607486412523203`*^9}, {3.960748731260859*^9, 
   3.960748734547347*^9}, 3.968868107688809*^9, {3.9693872602571297`*^9, 
   3.969387266661635*^9}, {3.969821109496101*^9, 
   3.9698211160295343`*^9}},ExpressionUUID->"3ed85116-d318-454e-aacd-\
a6caf77127fb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"G", "[", 
   RowBox[{"v_", ",", "t0_", ",", "d0_", ",", "c_", ",", "tp_"}], "]"}], ":=", 
  SqrtBox[
   RowBox[{"1", "-", 
    FractionBox[
     SuperscriptBox["v", "2"], 
     SuperscriptBox["c", "2"]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"t0", "-", "tp"}], ")"}], "2"], " ", 
      SuperscriptBox["v", "2"]}], 
     SuperscriptBox["d0", "2"]]}]]}]], "Input",
 CellChangeTimes->{{3.9693872331093197`*^9, 3.969387245226387*^9}},
 CellLabel->
  "In[583]:=",ExpressionUUID->"5319283a-4bf8-4d5d-a6a8-90eb37e37175"]
}, Open  ]],

