Cell[BoxData[
 RowBox[{
  RowBox[{"partialvX", "[", 
   RowBox[{"v_", ",", "t0_", ",", "d0_", ",", "fs_", ",", "c_", ",", "tp_"}], 
   "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"fs", " ", "v", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["d0", "4"], " ", 
        SuperscriptBox["v", "4"]}], "-", 
       RowBox[{
        SuperscriptBox["d0", "2"], " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"t0", "-", "tp"}], ")"}], "2"], " ", 
        SuperscriptBox["v", "6"]}], "+", 
       RowBox[{"3", " ", "c", " ", 
        SuperscriptBox["d0", "3"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "t0"}], "+", "tp"}], ")"}], " ", 
        SuperscriptBox["v", "4"], " ", 
        RowBox[{"G", "[", 
         RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], "]"}]}], 
       "+", 
       RowBox[{
        SuperscriptBox["c", "5"], " ", "d0", " ", 
        RowBox[{"(", 
         RowBox[{"t0", "-", "tp"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", 
           SuperscriptBox["d0", "2"]}], "+", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"t0", "-", "tp"}], ")"}], "2"], " ", 
           SuperscriptBox["v", "2"]}]}], ")"}], " ", 
        RowBox[{"G", "[", 
         RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], "]"}]}], 
       "+", 
       RowBox[{
        SuperscriptBox["c", "3"], " ", "d0", " ", 
        RowBox[{"(", 
         RowBox[{"t0", "-", "tp"}], ")"}], " ", 
        SuperscriptBox["v", "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["d0", "2"], "+", 
          RowBox[{"3", " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"t0", "-", "tp"}], ")"}], "2"], " ", 
           SuperscriptBox["v", "2"]}]}], ")"}], " ", 
        RowBox[{"G", "[", 
         RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], "]"}]}], 
       "+", 
       RowBox[{
        SuperscriptBox["c", "2"], " ", 
        SuperscriptBox["v", "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], " ", 
           SuperscriptBox["d0", "4"]}], "-", 
          RowBox[{"5", " ", 
           SuperscriptBox["d0", "2"], " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"t0", "-", "tp"}], ")"}], "2"], " ", 
           SuperscriptBox["v", "2"]}], "+", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"t0", "-", "tp"}], ")"}], "4"], " ", 
           SuperscriptBox["v", "4"]}]}], ")"}]}], "+", 
       RowBox[{
        SuperscriptBox["c", "4"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", 
           SuperscriptBox["d0", "4"]}], "+", 
          RowBox[{"6", " ", 
           SuperscriptBox["d0", "2"], " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"t0", "-", "tp"}], ")"}], "2"], " ", 
           SuperscriptBox["v", "2"]}], "+", 
          RowBox[{"3", " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"t0", "-", "tp"}], ")"}], "4"], " ", 
           SuperscriptBox["v", "4"]}]}], ")"}]}]}], ")"}]}], ")"}], "/", 
   RowBox[{"(", 
    RowBox[{"d0", " ", 
     RowBox[{"(", 
      RowBox[{"c", "-", "v"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"c", "+", "v"}], ")"}], " ", 
     RowBox[{"G", "[", 
      RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], "]"}], " ", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["d0", "2"], "+", 
       FractionBox[
        RowBox[{
         SuperscriptBox["c", "2"], " ", 
         SuperscriptBox["v", "2"], " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"c", " ", "t0"}], "-", 
            RowBox[{"c", " ", "tp"}], "+", 
            RowBox[{"d0", " ", 
             RowBox[{"G", "[", 
              RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], 
              "]"}]}]}], ")"}], "2"]}], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["c", "2"], "-", 
           SuperscriptBox["v", "2"]}], ")"}], "2"]]}]], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"c", " ", 
         RowBox[{"(", 
          RowBox[{"t0", "-", "tp"}], ")"}], " ", 
         SuperscriptBox["v", "2"]}], "+", 
        RowBox[{"d0", " ", 
         SuperscriptBox["v", "2"], " ", 
         RowBox[{"G", "[", 
          RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], "]"}]}], 
        "-", 
        RowBox[{
         SuperscriptBox["c", "2"], " ", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["d0", "2"], "+", 
           FractionBox[
            RowBox[{
             SuperscriptBox["c", "2"], " ", 
             SuperscriptBox["v", "2"], " ", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"c", " ", "t0"}], "-", 
                RowBox[{"c", " ", "tp"}], "+", 
                RowBox[{"d0", " ", 
                 RowBox[{"G", "[", 
                  RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], 
                  "]"}]}]}], ")"}], "2"]}], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               SuperscriptBox["c", "2"], "-", 
               SuperscriptBox["v", "2"]}], ")"}], "2"]]}]]}], "+", 
        RowBox[{
         SuperscriptBox["v", "2"], " ", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["d0", "2"], "+", 
           FractionBox[
            RowBox[{
             SuperscriptBox["c", "2"], " ", 
             SuperscriptBox["v", "2"], " ", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"c", " ", "t0"}], "-", 
                RowBox[{"c", " ", "tp"}], "+", 
                RowBox[{"d0", " ", 
                 RowBox[{"G", "[", 
                  RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], 
                  "]"}]}]}], ")"}], "2"]}], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               SuperscriptBox["c", "2"], "-", 
               SuperscriptBox["v", "2"]}], ")"}], "2"]]}]]}]}], ")"}], "2"]}],
     ")"}], " "}]}]], "Input",
 CellChangeTimes->{{3.969387293513541*^9, 3.969387347056278*^9}, 
