Cell[BoxData[
 RowBox[{
  RowBox[{"partialfsX", "[", 
   RowBox[{"v_", ",", "t0_", ",", "d0_", ",", "fs_", ",", "c_", ",", "tp_"}], 
   "]"}], ":=", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"1", "-", 
     FractionBox[
      RowBox[{
       SuperscriptBox["v", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"c", " ", "t0"}], "-", 
