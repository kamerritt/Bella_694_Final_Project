           "]"}]}]}], ")"}]}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["c", "2"], "-", 
         SuperscriptBox["v", "2"]}], ")"}], " ", 
       SqrtBox[
        RowBox[{
         SuperscriptBox["d0", "2"], "+", 
         FractionBox[
          RowBox[{
           SuperscriptBox["c", "2"], " ", 
