Cell[CellGroupData[{

Cell[TextData[{
 "Now we try to get the viewpoint from looking down on the plane of COP, \n\
with OC pointing ",
 StyleBox["up",
  FontWeight->"Bold"],
 " on the page.\nMathematica cannot seem to do this correctly.\nIt appears to \
get the normal direction correct, but not the ViewVertical."
}], "Section",
 CellChangeTimes->{{3.968058347903933*^9, 3.9680583777775803`*^9}, 
   3.968059971384872*^9, {3.968060938154085*^9, 3.968060942010098*^9}, {
