  RowBox[{"ShowTriB", "=", "True"}], ";"}]}], "Input",
 CellChangeTimes->{{3.968191153397595*^9, 3.968191155225593*^9}},
 CellLabel->"In[66]:=",ExpressionUUID->"4e5e0cff-4b34-464f-b534-f4c97ea79d9f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"cameraCOP", "[", "d_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"O", "=", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0"}], "}"}]}], ",", "C", ",", "uPath", 
       ",", "n", ",", "vUp"}], "}"}], ",", 
     RowBox[{
      RowBox[{"C", "=", 
       RowBox[{"QofT", "[", "0", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"uPath", "=", 
       RowBox[{"Normalize", "[", 
        RowBox[{
         RowBox[{"QofT", "[", "1", "]"}], "-", 
         RowBox[{"QofT", "[", 
          RowBox[{"-", "1"}], "]"}]}], "]"}]}], ";", 
      RowBox[{"n", "=", 
       RowBox[{"Normalize", "[", 
        RowBox[{"Cross", "[", 
         RowBox[{
          RowBox[{"Normalize", "[", "C", "]"}], ",", "uPath"}], "]"}], 
        "]"}]}], ";", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"n", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "<", "0"}], ",", 
        RowBox[{"n", "=", 
         RowBox[{"-", "n"}]}]}], "]"}], ";", 
      RowBox[{"vUp", "=", 
       RowBox[{"Normalize", "[", "C", "]"}]}], ";", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"ViewVector", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"O", "+", 
            RowBox[{"d", " ", "n"}]}], ",", "O"}], "}"}]}], ",", 
