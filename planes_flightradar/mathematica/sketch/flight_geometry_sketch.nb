             RowBox[{"plane", " ", "normal"}], "*)"}], 
            RowBox[{"b", "=", 
             RowBox[{"Normalize", "[", 
              RowBox[{"Cross", "[", 
               RowBox[{"n", ",", "u1"}], "]"}], "]"}]}], ";", 
            RowBox[{"(*", 
             RowBox[{"in", "-", 
              RowBox[{"plane", " ", "basis"}]}], "*)"}], 
            RowBox[{"\[Theta]", "=", 
             RowBox[{"VectorAngle", "[", 
              RowBox[{"u1", ",", "u2"}], "]"}]}], ";", 
            RowBox[{"(*", 
             RowBox[{
             "angle", " ", "at", " ", "O", " ", "between", " ", "OC", " ", 
              "and", " ", "OP"}], "*)"}], 
            RowBox[{"arcpts", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"oPt", "+", 
                RowBox[{"rArc", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"Cos", "[", "t", "]"}], " ", "u1"}], "+", 
                   RowBox[{
                    RowBox[{"Sin", "[", "t", "]"}], " ", "b"}]}], ")"}]}]}], 
               ",", 
               RowBox[{"{", 
                RowBox[{"t", ",", "0", ",", "\[Theta]", ",", 
                 RowBox[{"\[Theta]", "/", "40."}]}], "}"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"bis", "=", 
             RowBox[{
              RowBox[{
               RowBox[{"Cos", "[", 
                RowBox[{"\[Theta]", "/", "2"}], "]"}], " ", "u1"}], "+", 
              RowBox[{
               RowBox[{"Sin", "[", 
                RowBox[{"\[Theta]", "/", "2"}], "]"}], " ", "b"}]}]}], ";", 
            RowBox[{"(*", 
             RowBox[{"angle", " ", "bisector"}], "*)"}], 
            RowBox[{"rGamma", "=", 
             RowBox[{"0.8", " ", "rArc"}]}], ";", 
            RowBox[{"(*", 
             RowBox[{
             "label", " ", "a", " ", "bit", " ", "closer", " ", "to", " ", 
              "O"}], "*)"}], 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Thickness", "[", "tkns", "]"}], ",", 
              RowBox[{"Line", "[", "arcpts", "]"}], ",", 
              RowBox[{"If", "[", 
               RowBox[{"ShowText", ",", 
                RowBox[{"Text", "[", 
                 RowBox[{
                  RowBox[{"Style", "[", 
