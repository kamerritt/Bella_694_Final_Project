                   "\"\<\[Gamma]\>\"", ",", "fsize", ",", "Bold", ",", 
                    "Black"}], "]"}], ",", 
                  RowBox[{"oPt", "+", 
                   RowBox[{"rGamma", " ", "bis"}], "+", 
                   RowBox[{"{", 
                    RowBox[{"0.012", ",", "0.012", ",", "0.012"}], "}"}]}]}], 
                 "]"}], ",", "Nothing"}], "]"}]}], "}"}]}]}], "]"}]}], "]"}], 
