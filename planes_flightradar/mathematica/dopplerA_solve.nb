Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"tp", "==", 
     RowBox[{"t", "+", 
      FractionBox[
       SqrtBox[
        RowBox[{
         SuperscriptBox["d0", "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"v", " ", "t"}], ")"}], "2"]}]], "c"], "+", "t0"}]}], ",", 
    "t"}], "]"}], "]"}]], "Input",
