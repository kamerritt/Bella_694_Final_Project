Cell[CellGroupData[{

Cell["\<\
Solve the Doppler equation for t, with t0 defined as the aircraft time at \
closest approach:\
\>", "Subsection",
 CellChangeTimes->{{3.960055700726102*^9, 3.96005570986094*^9}, {
  3.9600557556439857`*^9, 3.960055766072599*^9}, {3.960831219637995*^9, 
