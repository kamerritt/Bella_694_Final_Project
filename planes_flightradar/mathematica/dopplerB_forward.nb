Cell[BoxData[{
 RowBox[{
  RowBox[{"SinGamma", "[", 
   RowBox[{"v_", ",", "t0_", ",", "d0_", ",", "c_", ",", "tp_"}], "]"}], ":=", 
  FractionBox[
   RowBox[{
    RowBox[{"-", "v"}], " ", 
    RowBox[{"t", "[", 
     RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], "]"}]}], 
   SqrtBox[
    RowBox[{
     SuperscriptBox["d0", "2"], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"v", " ", 
        RowBox[{"t", "[", 
         RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], "]"}]}], 
       ")"}], "2"]}]]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FfactorA", "[", 
   RowBox[{"v_", ",", "t0_", ",", "d0_", ",", "c_", ",", "tp_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["v", "c"], 
   RowBox[{"SinGamma", "[", 
    RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Ffactor", "[", 
    RowBox[{"v_", ",", "t0_", ",", "d0_", ",", "c_", ",", "tp_"}], "]"}], ":=", 
   RowBox[{"1", "-", 
    RowBox[{"FfactorA", "[", 
     RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Ft", "[", 
    RowBox[{"v_", ",", "t0_", ",", "d0_", ",", "fs_", ",", "c_", ",", "tp_"}],
     "]"}], ":=", 
   FractionBox["fs", 
    RowBox[{"Ffactor", "[", 
     RowBox[{"v", ",", "t0", ",", "d0", ",", "c", ",", "tp"}], "]"}]]}], 
  ";"}]}], "Input",
