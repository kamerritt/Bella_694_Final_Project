Cell[BoxData[
 RowBox[{
  RowBox[{"t", "[", 
   RowBox[{"v_", ",", "t0_", ",", "d0_", ",", "c_", ",", "tp_"}], "]"}], ":=", 
  FractionBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"tp", "-", "t0"}], ")"}], "-", 
    RowBox[{
     FractionBox["d0", "c"], 
     SqrtBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         FractionBox[
          SuperscriptBox["v", "2"], 
          SuperscriptBox["c", "2"]]}], ")"}], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"v", 
           RowBox[{"(", 
            RowBox[{"tp", "-", "t0"}], ")"}]}], "d0"], ")"}], "2"]}]]}]}], 
   RowBox[{"1", "-", 
    FractionBox[
     SuperscriptBox["v", "2"], 
     SuperscriptBox["c", "2"]]}]]}]], "Input",
 CellChangeTimes->{{3.969063677649564*^9, 3.9690636783073587`*^9}},
