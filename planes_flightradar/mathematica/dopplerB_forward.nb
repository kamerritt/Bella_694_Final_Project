18b62e876bea"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"tpfun", "[", "t_", "]"}], ":=", 
   RowBox[{"t", "+", "t0", "+", 
    RowBox[{
     SqrtBox[
      RowBox[{
       SuperscriptBox["d0", "2"], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"v", " ", "t"}], ")"}], "2"]}]], "/", "c"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.969063052709877*^9, 3.969063057717142*^9}, {
  3.96918490905595*^9, 3.969184929625383*^9}},
 CellLabel->
  "In[186]:=",ExpressionUUID->"ce1c093c-917a-450a-8d29-79195c583d53"],

